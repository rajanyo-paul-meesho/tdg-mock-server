    "version": "0.2.0",
    "configurations": [
        {
            "name": "rv-iop-grpc-web",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/rviopgrpcweb",
            "envFile": "${workspaceFolder}/cmd/rviopgrpcweb/sample.env",
            "env": {
                "APP_NAME": "rv-iop-grpc-web",
                // "ZOOKEEPER_SERVER": "zk1-mlp.prd.meesho.int:2181,zk2-mlp.prd.meesho.int:2181,zk3-mlp.prd.meesho.int:2181",
                "RV_INTERACTIONS_EXPLOIT_ONLINECG_HOST": "exploit-online-cg-web.prd.meesho.int",
                "RV_INTERACTIONS_EXPLOIT_ONLINECG_PORT": "80",
                "RV_INTERACTIONS_EXPLOIT_ONLINECG_TIMEOUT": "250",
                "RV_INTERACTIONS_EXPLOIT_ONLINECG_GRPC_PLAIN_TEXT": "true"
            }
        },
        {
            "name": "rv-iop-web",
            "type": "go",
            "request": "launch",
            "mode": "debug",
            "program": "${workspaceFolder}/cmd/rviopweb",
            "envFile": "${workspaceFolder}/cmd/rviopweb/sample.env"
        }
    ]
}

